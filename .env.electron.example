# Config for the Electron desktop build. Copy to .env.electron and fill in,
# or export these directly before running `npm run electron:build`.
#
# The web deployment's .env.production is untouched by this file — Electron
# is an additional distribution channel, not a replacement.

# Baked into the frontend bundle at build time (like all VITE_* vars — see
# CLAUDE.md). Electron loads the bundle from file://, where the web build's
# relative '/api' default has no meaningful host, so this must be the real,
# absolute API URL. src/lib/api.ts (axios baseURL) and
# src/hooks/useDaybookNotifications.ts (WebSocket origin, derived from this
# same value) both key off it.
VITE_API_BASE_URL=https://syncinvoice.in/api

# Read at Electron *runtime* (not build time) by electron/hook-server.cjs,
# which runs in the Node main process and has no access to import.meta.env —
# set this to the same value as VITE_API_BASE_URL above.
ELECTRON_API_BASE_URL=https://syncinvoice.in/api

# Port electron/hook-server.cjs listens on for Tally's FormAccept webhook.
# Must match extension/TallySyncBridge.tdl's two Action:HTTP Post URLs
# (currently http://127.0.0.1:8765/api/tally-hook) — port 80 needs elevated
# privileges on every OS tested, so a high port is the default on both sides.
# Only change this if you've also edited the TDL file to match.
TALLY_HOOK_PORT=8765
