# ── Frontend (Vite dev mode) ──────────────────────────────
# Real extension ID goes in .env.local
VITE_CHROME_EXTENSION_ID=
VITE_ALLOW_EXTENSION_MOCK=true
VITE_ALLOW_SYNC_MOCK=false

# ── Backend (local dev — postgres on localhost) ───────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/tally_bill_sync
PORT=3001
