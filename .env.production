# ── Frontend (Vite production build) ─────────────────────
# Real extension ID goes in .env.production.local
VITE_CHROME_EXTENSION_ID=
VITE_ALLOW_EXTENSION_MOCK=false
VITE_ALLOW_SYNC_MOCK=false

# ── Backend (Docker — "postgres" is the service hostname) ─
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/tally_bill_sync
PORT=3001
