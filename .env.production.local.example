# Production secrets — copy this file to .env.production.local on the server.
# .env.production.local is gitignored and MUST NOT be committed.

ANTHROPIC_API_KEY=sk-ant-your-production-key
GEMINI_API_KEY=AIzaSy-your-production-key
JWT_SECRET=use-a-long-random-string-minimum-32-chars

# From chrome://extensions — the published or sideloaded extension ID
VITE_CHROME_EXTENSION_ID=your-real-extension-id

# Postgres credentials (also used by the postgres service in docker-compose)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-this-to-a-strong-password
POSTGRES_DB=tally_bill_sync
DATABASE_URL=postgresql://postgres:change-this-to-a-strong-password@postgres:5432/tally_bill_sync
