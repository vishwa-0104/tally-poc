# ── Required ───────────────────────────────────────────────
# Anthropic API key for AI bill parsing (server-side, never sent to browser)
# Get one at: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Recommended to change in production ────────────────────
# Secret used to sign JWT tokens — use a long random string
JWT_SECRET=change-this-to-a-long-random-string

# ── Chrome Extension ────────────────────────────────────────
# The ID of the loaded Tally Bill Sync Chrome extension.
# Find it at chrome://extensions after loading the extension/  folder.
# Leave blank to use mock (dev/demo mode — sync won't hit real Tally).
VITE_CHROME_EXTENSION_ID=
