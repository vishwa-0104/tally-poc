{
  "name": "tally-bill-sync",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "type-check": "tsc --noEmit",
    "docker:dev": "docker-compose --env-file .env.local up --build",
    "docker:prod": "docker compose -f docker-compose.yml -f docker-compose.prod.yml --env-file .env.production up --build -d",
    "docker:db": "docker-compose up postgres -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "docker:psql": "docker-compose exec postgres psql -U ${POSTGRES_USER:-postgres} ${POSTGRES_DB:-tally_bill_sync}",
    "docker:psql-prod": "docker compose exec postgres psql -U ${POSTGRES_USER:-postgres} ${POSTGRES_DB:-tally_bill_sync}",
    "electron:dev": "concurrently -k \"vite\" \"wait-on http://localhost:3000 && NODE_ENV=development electron .\"",
    "electron:preview": "ELECTRON_BUILD=true tsc && ELECTRON_BUILD=true vite build --mode electron && NODE_ENV=production electron .",
    "electron:build": "ELECTRON_BUILD=true tsc && ELECTRON_BUILD=true vite build --mode electron && electron-builder",
    "electron:build:dir": "ELECTRON_BUILD=true tsc && ELECTRON_BUILD=true vite build --mode electron && electron-builder --dir"
  },
  "build": {
    "appId": "com.tallybillsync.desktop",
    "productName": "TallyBillSync",
    "files": [
      "dist/**/*",
      "electron/**/*",
      ".env.electron"
    ],
    "directories": {
      "buildResources": "build",
      "output": "release"
    },
    "mac": {
      "target": "dmg"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@hookform/resolvers": "^3.3.4",
    "@prisma/client": "^7.8.0",
    "axios": "^1.6.7",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.0",
    "date-fns": "^4.4.0",
    "dotenv": "^16.4.5",
    "lucide-react": "^0.330.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-dropzone": "^14.2.3",
    "react-hook-form": "^7.50.0",
    "react-hot-toast": "^2.4.1",
    "react-router-dom": "^6.22.0",
    "react-select": "^5.10.2",
    "react-type-animation": "^3.2.0",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^3.22.4",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.3",
    "@types/react": "^18.2.55",
    "@types/react-dom": "^18.2.19",
    "@typescript-eslint/eslint-plugin": "^7.0.2",
    "@typescript-eslint/parser": "^7.0.2",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "electron-updater": "^6.1.7",
    "eslint": "^8.56.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "postcss": "^8.4.35",
    "prisma": "^7.8.0",
    "tailwindcss": "^4.3.3",
    "typescript": "^5.2.2",
    "vite": "^5.1.0",
    "wait-on": "^7.2.0"
  }
}
