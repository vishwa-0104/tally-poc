generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  COMPANY
}

enum BillStatus {
  PENDING
  PARSED
  MAPPED
  SYNCED
  ERROR
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         Role     @default(COMPANY)
  company      Company? @relation(fields: [companyId], references: [id])
  companyId    String?
  createdAt    DateTime @default(now())
}

model Company {
  id             String         @id @default(cuid())
  name           String
  gstin          String?
  email          String         @unique
  port           Int            @default(9000)
  mapping        Json?
  voucherCounter Int            @default(0)
  bills            Bill[]
  users            User[]
  ledgerCache      LedgerCache[]
  stockItemCache   StockItemCache[]
  stockGroupCache  StockGroupCache[]
  stockUnitCache   StockUnitCache[]
  stockItemAliases StockItemAlias[]
  syncTimestamps   Json?
  createdAt        DateTime       @default(now())
}

model LedgerCache {
  id                  String  @id @default(cuid())
  company             Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyId           String
  name                String
  group               String  @default("")
  gstin               String?
  state               String?
  openingBalance      String?
  gstRegistrationType String?

  @@unique([companyId, name])
}

model Bill {
  id           String     @id @default(cuid())
  company      Company    @relation(fields: [companyId], references: [id])
  companyId    String
  billNumber   String
  vendorName   String
  vendorGstin  String?
  buyerGstin   String?
  billDate     String
  subtotal     Float
  cgstAmount   Float      @default(0)
  sgstAmount   Float      @default(0)
  igstAmount   Float      @default(0)
  totalAmount  Float
  status       BillStatus @default(PARSED)
  imageUrl     String?
  originalData Json?
  isEdited     Boolean    @default(false)
  rawAiJson    Json?
  tallyXml       String?
  tallyMapping   Json?
  roundOffAmount Float?
  syncedAt       DateTime?
  syncError    String?
  lineItems    LineItem[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model StockItemCache {
  id        String           @id @default(cuid())
  company   Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyId String
  name      String
  group     String           @default("")
  unit      String           @default("")
  aliases   StockItemAlias[]

  @@unique([companyId, name])
}

model StockItemAlias {
  id               String         @id @default(cuid())
  company          Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyId        String
  stockItem        StockItemCache @relation(fields: [stockItemCacheId], references: [id], onDelete: Cascade)
  stockItemCacheId String
  billItemName     String         // stored lowercase for case-insensitive lookup

  @@unique([companyId, billItemName])
}

model StockGroupCache {
  id        String  @id @default(cuid())
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyId String
  name      String
  parent    String  @default("")

  @@unique([companyId, name])
}

model StockUnitCache {
  id        String  @id @default(cuid())
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyId String
  name      String
  symbol    String  @default("")

  @@unique([companyId, name])
}

model LineItem {
  id              String  @id @default(cuid())
  bill            Bill    @relation(fields: [billId], references: [id], onDelete: Cascade)
  billId          String
  description     String
  hsnCode         String?
  quantity        Float
  unit            String
  unitPrice       Float
  discountPercent Float?
  gstRate         Float
  amount          Float
  tallyLedger     String?
  tallyStockItem  String?
}
