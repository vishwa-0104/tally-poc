generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  COMPANY
}

enum BillStatus {
  PENDING
  PARSED
  MAPPED
  SYNCED
  ERROR
}

model User {
  id              String        @id @default(cuid())
  name            String
  email           String        @unique
  passwordHash    String
  role            Role          @default(COMPANY)
  enterpriseName  String?
  linkedCompanies UserCompany[]
  createdAt       DateTime      @default(now())
}

model UserCompany {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyId String
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())

  @@unique([userId, companyId])
}

model Company {
  id             String         @id @default(cuid())
  name           String
  gstin          String?
  email          String?
  port           Int            @default(9000)
  mapping        Json?
  voucherCounter         Int       @default(0)
  parseBillsLimit        Int       @default(50)
  parseBillsUsed         Int       @default(0)
  parseBlocked           Boolean   @default(false)
  parseService           String    @default("gemini")
  parseModel             String    @default("gemini-flash-latest")
  subscriptionExpiresAt  DateTime?
  subscriptionRenewedAt  DateTime?
  bills            Bill[]
  linkedUsers      UserCompany[]
  parseUsageLogs   ParseUsageLog[]
  ledgerCache      LedgerCache[]
  stockItemCache   StockItemCache[]
  stockGroupCache  StockGroupCache[]
  stockUnitCache   StockUnitCache[]
  stockItemAliases StockItemAlias[]
  godownCache      GodownCache[]
  features         CompanyFeature[]
  syncTimestamps   Json?
  createdAt        DateTime       @default(now())
}

model ParseUsageLog {
  id           String   @id @default(cuid())
  company      Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyId    String
  model        String
  inputTokens  Int      @default(0)
  outputTokens Int      @default(0)
  cacheRead    Int      @default(0)
  cacheWrite   Int      @default(0)
  success      Boolean
  createdAt    DateTime @default(now())

  @@index([companyId, createdAt])
}

model CompanyFeature {
  id        String  @id @default(cuid())
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyId String
  feature   String
  enabled   Boolean @default(false)

  @@unique([companyId, feature])
}

model GodownCache {
  id        String  @id @default(cuid())
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyId String
  name      String

  @@unique([companyId, name])
}

model LedgerCache {
  id                  String  @id @default(cuid())
  company             Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyId           String
  name                String
  group               String  @default("")
  gstin               String?
  state               String?
  openingBalance      String?
  gstRegistrationType String?

  @@unique([companyId, name])
}

model Bill {
  id           String     @id @default(cuid())
  company      Company    @relation(fields: [companyId], references: [id])
  companyId    String
  billNumber   String
  vendorName   String
  vendorGstin  String?
  buyerGstin   String?
  billDate     String
  subtotal     Float
  cgstAmount   Float      @default(0)
  sgstAmount   Float      @default(0)
  igstAmount   Float      @default(0)
  totalAmount  Float
  status       BillStatus @default(PARSED)
  billType     String     @default("purchase")
  imageUrl     String?
  originalData Json?
  isEdited     Boolean    @default(false)
  rawAiJson    Json?
  tallyXml       String?
  tallyMapping   Json?
  roundOffAmount         Float?
  invoiceDiscountAmount  Float?
  extraCharges           Json?
  syncedAt       DateTime?
  syncError    String?
  lineItems    LineItem[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model StockItemCache {
  id        String           @id @default(cuid())
  company   Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyId String
  name      String
  group     String           @default("")
  unit      String           @default("")
  aliases   StockItemAlias[]

  @@unique([companyId, name])
}

model StockItemAlias {
  id               String         @id @default(cuid())
  company          Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyId        String
  stockItem        StockItemCache @relation(fields: [stockItemCacheId], references: [id], onDelete: Cascade)
  stockItemCacheId String
  billItemName     String         // stored lowercase for case-insensitive lookup

  @@unique([companyId, billItemName])
}

model StockGroupCache {
  id        String  @id @default(cuid())
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyId String
  name      String
  parent    String  @default("")

  @@unique([companyId, name])
}

model StockUnitCache {
  id        String  @id @default(cuid())
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyId String
  name      String
  symbol    String  @default("")

  @@unique([companyId, name])
}

enum LeadStatus {
  NEW_LEAD
  ONBOARDED
  NOT_ONBOARDED
  REJECTED
}

model Lead {
  id          String     @id @default(cuid())
  companyName String
  phone       String
  email       String
  description String?
  status      LeadStatus @default(NEW_LEAD)
  remarks     String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model LineItem {
  id              String  @id @default(cuid())
  bill            Bill    @relation(fields: [billId], references: [id], onDelete: Cascade)
  billId          String
  description     String
  hsnCode         String?
  quantity        Float
  unit            String
  unitPrice       Float
  discountPercent Float?
  discountAmount  Float?
  gstRate         Float
  amount          Float
  tallyLedger     String?
  tallyStockItem  String?
}
