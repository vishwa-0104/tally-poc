generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  COMPANY
}

enum BillStatus {
  PENDING
  PARSED
  MAPPED
  SYNCED
  ERROR
}

model User {
  id              String        @id @default(cuid())
  name            String
  email           String        @unique
  passwordHash    String
  role            Role          @default(COMPANY)
  enterpriseName  String?
  linkedCompanies UserCompany[]
  createdAt       DateTime      @default(now())
}

model UserCompany {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyId String
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())

  @@unique([userId, companyId])
}

model Company {
  id             String         @id @default(cuid())
  name           String
  gstin          String?
  email          String?
  port           Int            @default(9000)
  mapping        Json?
  voucherCounter         Int       @default(0)
  parseBillsLimit        Int       @default(50)
  parseBillsUsed         Int       @default(0)
  parseBlocked           Boolean   @default(false)
  parseService           String    @default("gemini")
  parseModel             String    @default("gemini-flash-latest")
  subscriptionExpiresAt  DateTime?
  subscriptionRenewedAt  DateTime?
  bills            Bill[]
  linkedUsers      UserCompany[]
  parseUsageLogs   ParseUsageLog[]
  ledgerCache      LedgerCache[]
  stockItemCache   StockItemCache[]
  stockGroupCache  StockGroupCache[]
  stockUnitCache   StockUnitCache[]
  stockItemAliases StockItemAlias[]
  godownCache      GodownCache[]
  voucherTypeCache VoucherTypeCache[]
  features         CompanyFeature[]
  bankSyncLogs     BankSyncLog[]
  cashBookSyncLogs CashBookSyncLog[]
  salesTargets     SalesTarget[]
  vouchers         Voucher[]
  voucherFetchLogs VoucherFetchLog[]
  dashboardSnapshot DashboardSnapshot?
  voucherType       String         @default("GST PURCHASE")
  syncTimestamps    Json?
  dashboardSettings Json?
  createdAt         DateTime       @default(now())
}

model ParseUsageLog {
  id           String   @id @default(cuid())
  company      Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyId    String
  model        String
  inputTokens  Int      @default(0)
  outputTokens Int      @default(0)
  cacheRead    Int      @default(0)
  cacheWrite   Int      @default(0)
  success      Boolean
  rawUsage     Json?
  createdAt    DateTime @default(now())

  @@index([companyId, createdAt])
}

model CompanyFeature {
  id        String  @id @default(cuid())
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyId String
  feature   String
  enabled   Boolean @default(false)

  @@unique([companyId, feature])
}

model VoucherTypeCache {
  id        String  @id @default(cuid())
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyId String
  name      String

  @@unique([companyId, name])
}

model GodownCache {
  id        String  @id @default(cuid())
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyId String
  name      String

  @@unique([companyId, name])
}

model LedgerCache {
  id                  String  @id @default(cuid())
  company             Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyId           String
  name                String
  group               String  @default("")
  gstin               String?
  state               String?
  openingBalance      String?
  gstRegistrationType String?

  @@unique([companyId, name])
}

model Bill {
  id           String     @id @default(cuid())
  company      Company    @relation(fields: [companyId], references: [id])
  companyId    String
  billNumber   String
  vendorName   String
  vendorGstin  String?
  buyerGstin   String?
  billDate     String
  subtotal     Float
  cgstAmount   Float      @default(0)
  sgstAmount   Float      @default(0)
  igstAmount   Float      @default(0)
  totalAmount  Float
  status       BillStatus @default(PARSED)
  billType     String     @default("purchase")
  imageUrl     String?
  originalData Json?
  isEdited     Boolean    @default(false)
  rawAiJson    Json?
  tallyXml       String?
  tallyMapping   Json?
  roundOffAmount         Float?
  invoiceDiscountAmount  Float?
  extraCharges           Json?
  syncedAt       DateTime?
  syncError    String?
  lineItems    LineItem[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model StockItemCache {
  id        String           @id @default(cuid())
  company   Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyId String
  name      String
  group     String           @default("")
  unit      String           @default("")
  aliases   StockItemAlias[]

  @@unique([companyId, name])
}

model StockItemAlias {
  id               String         @id @default(cuid())
  company          Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyId        String
  stockItem        StockItemCache @relation(fields: [stockItemCacheId], references: [id], onDelete: Cascade)
  stockItemCacheId String
  billItemName     String         // stored lowercase for case-insensitive lookup

  @@unique([companyId, billItemName])
}

model StockGroupCache {
  id        String  @id @default(cuid())
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyId String
  name      String
  parent    String  @default("")

  @@unique([companyId, name])
}

model StockUnitCache {
  id        String  @id @default(cuid())
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyId String
  name      String
  symbol    String  @default("")

  @@unique([companyId, name])
}

model BankSyncLog {
  id          String   @id @default(cuid())
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyId   String
  fingerprint String
  createdAt   DateTime @default(now())

  @@unique([companyId, fingerprint])
  @@index([companyId])
}

model CashBookSyncLog {
  id          String   @id @default(cuid())
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyId   String
  fingerprint String
  createdAt   DateTime @default(now())

  @@unique([companyId, fingerprint])
  @@index([companyId])
}

enum LeadStatus {
  NEW_LEAD
  ONBOARDED
  NOT_ONBOARDED
  REJECTED
}

model Lead {
  id          String     @id @default(cuid())
  companyName String
  phone       String
  email       String
  description String?
  status      LeadStatus @default(NEW_LEAD)
  remarks     String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model SalesTarget {
  id        String  @id @default(cuid())
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyId String
  fyYear    Int     // FY start year: 2025 = FY2025-26 (Apr 2025 – Mar 2026)
  month     Int     // calendar month 1–12
  target    Float

  @@unique([companyId, fyYear, month])
}

model LineItem {
  id              String  @id @default(cuid())
  bill            Bill    @relation(fields: [billId], references: [id], onDelete: Cascade)
  billId          String
  description     String
  hsnCode         String?
  quantity        Float
  unit            String
  unitPrice       Float
  discountPercent Float?
  discountAmount  Float?
  gstRate         Float
  amount          Float
  tallyLedger     String?
  tallyStockItem  String?
}

// Append-only voucher history — a Tally edit (new AlterID) inserts a new row
// rather than overwriting; isLatest marks the current version per identityKey.
// identityKey = Tally's GUID when present, else `${voucherNo}::${type}` —
// voucherNo alone isn't safe since each voucher type numbers its own series.
model Voucher {
  id               String   @id @default(cuid())
  company          Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyId        String
  identityKey      String
  date             String   // YYYY-MM-DD
  type             String
  party            String
  voucherNo        String
  amount           Float
  taxableAmount    Float
  alterId          String
  guid             String?
  hasSalesLedger   Boolean  @default(false)
  salesLedger      String?
  purchaseLedger   String?
  isLatest         Boolean  @default(true)
  fetchedAt        DateTime @default(now())
  ledgerEntries    VoucherLedgerEntry[]
  inventoryEntries VoucherInventoryEntry[]

  @@unique([companyId, identityKey, alterId])
  @@index([companyId, date])
  @@index([companyId, identityKey])
}

model VoucherLedgerEntry {
  id            String  @id @default(cuid())
  voucher       Voucher @relation(fields: [voucherId], references: [id], onDelete: Cascade)
  voucherId     String
  ledgerName    String
  amount        Float
  isPartyLedger Boolean @default(false)
}

model VoucherInventoryEntry {
  id        String  @id @default(cuid())
  voucher   Voucher @relation(fields: [voucherId], references: [id], onDelete: Cascade)
  voucherId String
  itemName  String
  qty       Float
  unit      String
  amount    Float
}

// Marks which calendar dates have been fetched from Tally at least once,
// even if zero vouchers existed that day — without this, a genuinely
// voucher-free day is indistinguishable from "never fetched" when reading
// from the DB. Used for empty-state messaging only, not for gating —
// tab/filter switches never auto-fetch regardless of coverage.
model VoucherFetchLog {
  id        String   @id @default(cuid())
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyId String
  date      String
  fetchedAt DateTime @default(now())

  @@unique([companyId, date])
}

// One row per company — latest known values for snapshot-style Tally queries
// (closing balances, receivables/payables, stock value, slow-stock) that
// Tally itself can only report "as of now", not for an arbitrary past date.
model DashboardSnapshot {
  id                 String   @id @default(cuid())
  company            Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyId          String   @unique
  cashInHand         Float?
  bankBalance        Float?
  receivables        Float?
  payables           Float?
  openingStock       Float?
  closingStock       Float?
  directExpenseTotal Float?
  slowStockItems     Json?
  debtorBalances     Json?
  // Analysis-tab ratio KPIs — same "as of now" limitation as the fields above.
  equity             Float?
  investments        Float?
  currentLiabilities Float?
  fixedAssets        Float?
  totalLoans         Float?
  bankOD             Float?
  // ROCE's Long Term Borrowings — closing balance of specific configured
  // ledgers (like equity/totalLoans above, an "as of now" figure, not a
  // period-scoped flow), since Tally has no long-term/short-term group split.
  longTermBorrowings Float?
  // ROCE's own Equity figure — every ratio has its own dedicated Equity/
  // Loans/Cash/Bank settings rather than sharing one figure.
  roceEquity         Float?
  // ROE denominator pieces (Net Profit reuses the existing YTD figure, no
  // column needed for that).
  roeEquity          Float?
  internalBorrowings Float?
  intangibleAssets   Float?
  // Debt/Equity — every component of its own formula, independent of
  // Cash/Bank/Equity/Loans used by other cards.
  debtEquityLoans    Float?
  debtEquityCash     Float?
  debtEquityBank     Float?
  debtEquityEquity   Float?
  // Period-scoped ledger-list totals (same convention as directExpenseTotal
  // above — latest fetched period's total, not literally "as of now").
  interestExpenseTotal       Float?
  taxPaymentTotal            Float?
  nonOperatingIncomeTotal    Float?
  nonOperatingInvestmentTotal Float?
  directorLoansTotal         Float?
  fetchedAt          DateTime @default(now())
}
