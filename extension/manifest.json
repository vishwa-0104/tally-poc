{
  "manifest_version": 3,
  "name": "Invoice Sync",
  "version": "1.0.0",
  "description": "Connects Invoice Bill Sync web app to your local Invoice ERP server.",

  "externally_connectable": {
    "matches": ["https://syncinvoice.in/*"]
  },
  "host_permissions": [
    "http://localhost/*",
    "http://127.0.0.1/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_popup": "popup.html",
    "default_title": "Invoice Sync"
  },

  "content_scripts": [
    {
      "matches": ["http://localhost/*", "http://127.0.0.1/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ]
}
